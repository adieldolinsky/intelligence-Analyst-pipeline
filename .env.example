# n8n core
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
GENERIC_TIMEZONE=UTC

# Required: persist encrypted credentials across container restarts.
# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=replace-with-a-32-byte-hex-string

# Metadata enrichment API (exposed on host for debugging)
METADATA_API_PORT=5000
FLASK_DEBUG=0

# Configure these credentials inside the n8n UI after import (not in .env):
# - Google Gemini API key (HTTP Header Auth or Gemini credential)
# - Gmail OAuth2 (email notifications)
# - Google Sheets OAuth2 (audit log)
